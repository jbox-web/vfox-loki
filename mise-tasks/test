#!/usr/bin/env bash
#MISE description="Run plugin tests - install and execute tool"
set -euo pipefail

mise plugin link --force loki .
mise cache clear
mise install loki@3.5.12

# Capture and display the output while also verifying it
output=$(mise exec "loki@3.5.12" -- "loki" --version)
echo "loki output: ${output}"

if echo "${output}" | grep -q '3.5.12'; then
  echo "✓ Tests passed"
else
  echo "✗ Test failed: expected version loki@3.5.12"
  exit 1
fi
